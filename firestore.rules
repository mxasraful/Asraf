rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read for all portfolio collections
    // Allow admin write (auth required)
    match /profile/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /about/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /skills/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /projects/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /services/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /navigation/{doc} { allow read: if true; allow write: if request.auth != null; } // Used for Header Menu

    // Messages: Public can create, only admin can read/delete
    match /messages/{doc} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

    // Fallback for other items
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}